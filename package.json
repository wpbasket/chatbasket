{
  "name": "chatbasket",
  "main": "index.ts",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "startc": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest --forceExit",
    "build-web": "npx expo export -p web -c",
    "deploy-web": "npm run build-web && npx tsx scripts/fix-cloudflare-pages.ts && npx wrangler pages deploy dist && npx tsx scripts/prune-pages-deployments.ts",
    "deploy-android": "eas build --platform android --profile development"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^15.0.1",
    "@expo/vector-icons": "^15.1.1",
    "@legendapp/list": "^2.0.19",
    "@legendapp/motion": "^2.5.3",
    "@legendapp/state": "^3.0.0-beta.47",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "expo": "~56.0.11",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-blur": "~56.0.3",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.6",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.18",
    "expo-image-picker": "~56.0.17",
    "expo-intent-launcher": "~56.0.4",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-media-library": "~56.0.7",
    "expo-notifications": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-share-intent": "^6.1.1",
    "expo-sharing": "~56.0.17",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-video": "~56.1.3",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-libsodium": "^1.7.0",
    "react-native-mime-types": "^2.5.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-unistyles": "^3.2.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.2",
    "react-native-webrtc": "^124.0.7",
    "react-native-worklets": "^0.8.3"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.15",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3",
    "wrangler": "^4.98.0"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "private": true,
  "overrides": {
    "expo-sqlite": "$expo-sqlite",
    "expo-constants": "$expo-constants",
    "expo-linking": "$expo-linking",
    "@config-plugins/react-native-webrtc": {
      "expo": "$expo"
    },
    "expo-share-intent": {
      "expo": "$expo"
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-libsodium",
          "react-native-webrtc",
          "save-to-device"
        ]
      }
    }
  }
}
